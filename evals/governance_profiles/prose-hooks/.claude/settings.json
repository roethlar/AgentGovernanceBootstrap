{
  "hooks": {
    "Stop": [
      {"hooks": [
        {"type": "command",
         "command": "sh -c 'if [ -n \"$AGB_HOOK_SENTINEL\" ]; then echo fired >> \"$AGB_HOOK_SENTINEL\"; fi'"},
        {"type": "command", "command": "python3 .claude/hooks/gate.py"}
      ]}
    ],
    "PreToolUse": [
      {"matcher": "Edit|Write|MultiEdit|NotebookEdit",
       "hooks": [{"type": "command", "command": "python3 .claude/hooks/guard.py"}]}
    ]
  }
}
